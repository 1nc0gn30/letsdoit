# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"

# Database connection — set ONE of these in your Netlify site settings:
#   NETLIFY_DB_URL : Preferred. Copy the "Pooled" connection string from your Netlify Database dashboard.
#   DATABASE_URL   : Fallback for any external Postgres (Supabase, Neon, Railway, etc.).
NETLIFY_DB_URL="postgres://..."
DATABASE_URL="postgres://..."
